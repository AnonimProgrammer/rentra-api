meta {
  name: Continue Auth - Password Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/v1/auth/continue
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "provider": "PASSWORD",
    "credentials": {
      "email": "test@gmail.com",
      "password": "11111111"
    }
  }
}
