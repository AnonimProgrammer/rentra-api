meta {
  name: Continue Auth - Google Signup (first time)
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/v1/auth/continue
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "provider": "GOOGLE",
    "credentials": {
      "idToken": "{{googleIdToken}}"
    },
    "profile": {
      "firstName": "Test",
      "lastName": "Test",
      "email": "test@gmail.com",
      "birthDate": "1998-04-15"
    }
  }
}
