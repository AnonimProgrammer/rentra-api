meta {
  name: Continue Auth - Google Login (existing user)
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/v1/auth/continue
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "provider": "GOOGLE",
    "credentials": {
      "idToken": "{{googleIdToken}}"
    }
  }
}
