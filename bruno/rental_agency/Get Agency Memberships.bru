meta {
  name: Get Agency Memberships (cursor=userId)
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/v1/agencies/{{agencyId}}/memberships
  body: none
  auth: inherit
}

params:query {
  ~note: cursor points to userId from previous page
  ~cursor: {{cursorId}}
  ~limit: {{limit}}
  ~role: FRONT_AGENT
  ~status: ACTIVE
}
