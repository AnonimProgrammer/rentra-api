meta {
  name: Continue Auth - Password Signup
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/v1/auth/continue
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "provider": "PASSWORD",
    "credentials": {
      "email": "test@gmail.com",
      "password": "11111111"
    },
    "profile": {
      "firstName": "Test",
      "lastName": "Test",
      "email": "test@gmail.com",
      "birthDate": "1998-04-15"
    }
  }
}
